# ── AgentWorks 环境变量模板 ──
# 复制此文件为 .env 并填入真实值
# 所有变量名与 configs/*.yaml 中的引用保持一致

# OpenAI 服务密钥（必填）
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic 服务密钥（可选）
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# SQLite 检查点数据库文件路径（默认 ./agentworks_checkpoints.db）
CHECKPOINT_DB_PATH=./agentworks_checkpoints.db

# LangSmith 可观测性
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your-langsmith-key-here
LANGCHAIN_PROJECT=agentworks
